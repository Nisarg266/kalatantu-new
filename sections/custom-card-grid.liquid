{% schema %}
{
  "name": "Custom Card Grid",
  "settings": [
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "default": 1600
    },
    {
      "type": "range",
      "id": "card_gap_desktop",
      "label": "Card gap (desktop)",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "card_gap_mobile",
      "label": "Card gap (mobile)",
      "min": 0,
      "max": 40,
      "step": 5,
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Section padding top (desktop)",
      "min": 0,
      "max": 150,
      "step": 10,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Section padding bottom (desktop)",
      "min": 0,
      "max": 150,
      "step": 10,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Section padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Section padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "description", "label": "Description" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Learn more" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Custom Card Grid"
    }
  ]
}
{% endschema %}

<style>
.custom-card-section {
  background: {{ section.settings.section_bg }};
}

.custom-card-container {
  max-width: {{ section.settings.container_width }}px;
  margin: auto;

  /* ✅ ADDED LEFT & RIGHT PADDING */
  padding-left: 40px;
  padding-right: 40px;

  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}

.custom-card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: {{ section.settings.card_gap_desktop }}px;
}

.custom-card {
  background: {{ section.settings.card_bg }};
  border-radius: {{ section.settings.card_radius }}px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: all 0.35s ease;
}

/* ✨ Elegant subtle hover effect */
.custom-card:hover {
  box-shadow:
    0 8px 25px rgba(0, 0, 0, 0.6),   /* soft outer shadow */
    inset 0 0 10px rgba(0, 0, 0, 0.03); /* very light inner shadow */

  transform: translateY(-3px);
}

/* ✅ UPDATED IMAGE RATIO TO 1080x1920 (9:16) */
.custom-card-image {
  aspect-ratio: 9 / 16;
  width: 100%;
  overflow: hidden;
}

.custom-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.custom-card-content {
  padding: 20px;
}

.custom-card-title {
  font-size: 18px;
  font-weight: 600;
  color: #000000;
  margin-bottom: 10px;
}

.custom-card-description {
  font-size: 14px;
  color: #545454;
  margin-bottom: 15px;
}

.custom-card-link {
  font-size: 14px;
  color: #545454;
  text-decoration: none;
  transition: 0.3s ease;
}

.custom-card-link:hover {
  color: #000000;
}

@media (max-width: 768px) {
  .custom-card-container {

    /* ✅ Mobile left/right padding */
    padding-left: 20px;
    padding-right: 20px;

    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .custom-card-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: {{ section.settings.card_gap_mobile }}px;
  }

  .custom-card-content {
    padding: 15px;
  }

  .custom-card-title {
    font-size: 16px;
  }

  .custom-card-description {
    font-size: 13px;
  }
}
</style>

<section class="custom-card-section">
  <div class="custom-card-container">
    <div class="custom-card-grid">
      {% for block in section.blocks %}
        <div class="custom-card" {{ block.shopify_attributes }}>
          
          {% if block.settings.image != blank %}
          <div class="custom-card-image">
            <img 
              src="{{ block.settings.image | image_url: width: 1080 }}" 
              alt="{{ block.settings.title | escape }}">
          </div>
          {% endif %}

          <div class="custom-card-content">
            {% if block.settings.title != blank %}
              <div class="custom-card-title">
                {{ block.settings.title }}
              </div>
            {% endif %}

            {% if block.settings.description != blank %}
              <div class="custom-card-description">
                {{ block.settings.description }}
              </div>
            {% endif %}

            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="custom-card-link">
                {{ block.settings.link_text }}
              </a>
            {% endif %}
          </div>

        </div>
      {% endfor %}
    </div>
  </div>
</section>