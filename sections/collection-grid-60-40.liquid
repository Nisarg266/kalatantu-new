{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .grid-60-40-wrapper {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .grid-60-40 {
    display: grid;
    /* 3fr (60%) and 2fr (40%) */
    grid-template-columns: 3fr 2fr;
    gap: {{ section.settings.gap }}px;
    align-items: stretch;
  }

  .grid-60-40__item {
    position: relative;
    min-height: {{ section.settings.desktop_height }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 30px;
    text-decoration: none;
    color: #fff;
    border-radius: 4px;
  }

  .grid-60-40__image {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .grid-60-40__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .grid-60-40__item:hover .grid-60-40__image img {
    transform: scale(1.05);
  }

  .grid-60-40__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 50%, rgba(0,0,0,0.5) 100%);
    z-index: 2;
  }

  .grid-60-40__content {
    position: relative;
    z-index: 3;
  }

  .grid-60-40__title {
    font-size: 1.8rem;
    margin: 0 0 10px 0;
    font-weight: 600;
  }

  .grid-60-40__link {
    display: inline-block;
    border-bottom: 2px solid #fff;
    padding-bottom: 4px;
    font-weight: 500;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  /* Responsive Stack */
  @media screen and (max-width: 768px) {
    .grid-60-40 {
      grid-template-columns: 1fr;
    }
    
    .grid-60-40__item {
      min-height: 350px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding">
  <div class="grid-60-40-wrapper">
    
    {% if section.settings.heading != blank %}
      <h2 style="margin-bottom: 30px; text-align: center;">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="grid-60-40">
      {% for block in section.blocks limit: 2 %}
        <a href="{{ block.settings.link | default: '#' }}" class="grid-60-40__item" {{ block.shopify_attributes }}>
          
          <div class="grid-60-40__image">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
            {% else %}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>

          <div class="grid-60-40__overlay"></div>

          <div class="grid-60-40__content">
            {% if block.settings.title != blank %}
              <h3 class="grid-60-40__title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.button_label != blank %}
              <span class="grid-60-40__link">{{ block.settings.button_label }}</span>
            {% endif %}
          </div>

        </a>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "60-40 Split Grid",
  "max_blocks": 2,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container Width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "default": 1400
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop Height",
      "min": 300,
      "max": 800,
      "step": 20,
      "default": 500
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Column Gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0, "max": 100, "step": 4, "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0, "max": 100, "step": 4, "default": 40
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "60-40 Split Grid",
      "blocks": [
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}