{% doc %}
  @prompt
    create a card section rectangle 2:3 with image on top and content on bottom make sure border radius of card is controllable. 
    
    In Desktop 3 per row
    in mobile version 2 per row, add a feature where i can decide how many cards i can add and content will be added acoording to that
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-card-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-card-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .ai-card-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-card-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-card-item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .ai-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 150%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.3;
  }

  .ai-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.description_spacing }}px;
  }

  .ai-card-link-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .ai-card-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-card-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-card-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 0 {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-card-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
    }

    .ai-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-card-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-card-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-card-container-{{ ai_gen_id }}">
    <div class="ai-card-grid-{{ ai_gen_id }}">
      {% for i in (1..block.settings.number_of_cards) %}
        {% liquid
          assign image_key = 'card_image_' | append: i
          assign title_key = 'card_title_' | append: i
          assign description_key = 'card_description_' | append: i
          assign link_key = 'card_link_' | append: i
          assign link_text_key = 'card_link_text_' | append: i

          assign card_image = block.settings[image_key]
          assign card_title = block.settings[title_key]
          assign card_description = block.settings[description_key]
          assign card_link = block.settings[link_key]
          assign card_link_text = block.settings[link_text_key]
        %}

        <div class="ai-card-item-{{ ai_gen_id }}">
          <div class="ai-card-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="ai-card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_description != blank %}
              <div class="ai-card-description-{{ ai_gen_id }}">{{ card_description }}</div>
            {% endif %}

            {% if card_link != blank and card_link_text != blank %}
              <a href="{{ card_link }}" class="ai-card-link-{{ ai_gen_id }}">
                {{ card_link_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

