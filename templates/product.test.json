rafts_tab | metafield_tag }}","page":""}},"tab_html_UhFFxX":{"type":"tab_html","settings":{"title":"Contact Us","content":"<p><strong>Have a question? Always Happy to help :)<\/strong><\/p><p>Reach out to us:<\/p><p><strong>Phone : <\/strong><a href=\"tel:+91 9033069795\" title=\"tel:+91 9033069797\">+91 90330 69797<\/a><\/p><p><strong>Email : <\/strong><a href=\"mailto:info@kalatantu.com\" title=\"mailto:info@kalatantu.com\">info@kalatantu.com<\/a><\/p><p><strong>Address :<\/strong> 604, 6th floor BTS-1 \/ Crown 1, Inspire Business Park, Shantigram Township, Gandhinagar 382421 Gujarat, India<\/p>","page":""}},"9866bb5f-03b7-4dc7-9387-4be849a0cbf1":{"type":"tab_add","disabled":true,"settings":{"title":"Additional Information"}},"d0839947-6bc5-42cc-85f7-9e94ce6b3e6c":{"type":"tab_html","disabled":true,"settings":{"title":"Return Policies","content":"","page":"privacy-policy"}},"1bc528a7-9da8-48ec-96da-8e48c0e52faf":{"type":"tab_html","disabled":true,"settings":{"title":"Custom tab","content":"","page":"wash-care"}}},"block_order":["76effdab-2914-4a34-a303-417cde99ff0a","tab_html_qMmF4D","tab_html_P4Xtjr","tab_html_yF8XBh","tab_html_VbWAPR","tab_html_YkdUW8","tab_html_RyTtCK","tab_html_UhFFxX","9866bb5f-03b7-4dc7-9387-4be849a0cbf1","d0839947-6bc5-42cc-85f7-9e94ce6b3e6c","1bc528a7-9da8-48ec-96da-8e48c0e52faf"],"disabled":true,"settings":{"tabs_design":"tab","enable_first_tab":false,"color_scheme":"scheme-1","padding_top":0,"padding_bottom":80,"padding_rate":50}},"sidebar":{"type":"sidebar-product","blocks":{"93375155-f1f0-4598-8fc0-9adcbad23dff":{"type":"iconbox","settings":{"widget_heading":"Shipping & Delivery","image_size":false,"icon_svg1":"box","custom_svg1":"","iconbox_content1":"Free shipping_Free shipping for all US orders","link_item1":"","icon_svg2":"support","custom_svg2":"","iconbox_content2":"Premium Support_Support 24 hours a day","link_item2":"","icon_svg3":"return","custom_svg3":"","iconbox_content3":"30 Days Return_ You have 30 days to return","link_it